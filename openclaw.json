{
  "gateway": {
    "port": 8080,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "${OPENCLAW_AGENT_MODEL:-anthropic/claude-sonnet-4-5}"
      },
      "maxConcurrent": 3,
      "timeoutSeconds": 72000,
      "workspace": "/data/workspace"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "OpenClaw",
        "identity": { "name": "OpenClaw" }
      }
    ]
  },
  "models": {
    "providers": {
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      }
    }
  },
  "channels": {
    "wechat-access": {
      "enabled": true,
      "token": "${WECHAT_TOKEN:-placeholder-replace-me}",
      "wsUrl": "${QCLAW_WECHAT_WS_URL:-wss://placeholder/ws}",
      "guid": "${WECHAT_GUID:-placeholder}",
      "userId": "${WECHAT_USERID:-0}"
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "qclaw-llm-provider",
      "ollama"
    ]
  }
}